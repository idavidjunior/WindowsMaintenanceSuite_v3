{
  "name": "windows-maintenance-suite",
  "version": "1.0.0",
  "description": "Windows Maintenance Suite - Interface Visual",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win dir",
    "dist": "electron-builder --win portable --x64"
  },
  "build": {
    "appId": "com.wms.gui",
    "productName": "Windows Maintenance Suite",
    "directories": {
      "output": "dist_v3"
    },
    "win": {
      "target": ["portable"],
      "icon": null
    },
    "portable": {
      "artifactName": "WindowsMaintenanceSuite.exe"
    },
    "asar": false,
    "files": [
      "*.js",
      "*.html",
      "*.css",
      "*.json",
      "gui-run.ps1",
      "get-health.ps1",
      "!node_modules/**"
    ],
    "extraResources": [
      {
        "from": "..",
        "to": "app",
        "filter": [
          "**/*",
          "!WindowGUI/**",
          "!WindowGUI/node_modules/**",
          "!.git/**",
          "!Logs/**",
          "!History/**",
          "!Reports/**"
        ]
      }
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
